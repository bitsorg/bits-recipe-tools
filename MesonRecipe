# MesonRecipe — standard recipe for Meson-based packages (bits-recipe-tools)
#
# Overrideable variables (set before or after sourcing this file):
#   MESON_BUILDDIR        build subdirectory name (default: _build)
#   MESON_EXTRA_OPTIONS   extra flags passed to meson setup (default: empty)
#
# Override Configure() to pass package-specific flags:
#
#   function Configure() {
#     meson setup "${MESON_BUILDDIR}" \
#       --prefix="$INSTALLROOT" \
#       -Dfoo=enabled \
#       ${MESON_EXTRA_OPTIONS}
#   }

MESON_BUILDDIR="${MESON_BUILDDIR:-_build}"

# The meson binary was installed by pip into MESON_ROOT with the bits Python
# shebang, but that Python's sys.path does not include MESON_ROOT's
# site-packages.  This function is called at the start of every meson
# invocation so mesonbuild is importable at build execution time (not just
# at recipe source/SPEC compile time).
function _meson_fixenv() {
  if [ -n "${MESON_ROOT}" ]; then
    local _pyver
    _pyver=$(python3 -c 'import sys; print("%d.%d" % sys.version_info[:2])' 2>/dev/null)
    export PYTHONPATH="${MESON_ROOT}/lib/python${_pyver}/site-packages${PYTHONPATH:+:${PYTHONPATH}}"
  fi
}

function Prepare() {
  # Set PYTHONPATH early so mesonbuild is importable in every subsequent
  # function — including custom Configure() overrides that don't call
  # _meson_fixenv themselves.  The export persists for the whole SPEC run.
  _meson_fixenv
  rsync -av --delete --exclude '**/.git' --delete-excluded "${SOURCEDIR}"/ ./
}

function Configure() {
  _meson_fixenv
  meson setup "${MESON_BUILDDIR}" --prefix="$INSTALLROOT" ${MESON_EXTRA_OPTIONS}
}

function Make() {
  _meson_fixenv
  meson compile -C "${MESON_BUILDDIR}"
}

function UnitTest() {
  true
}

function MakeInstall() {
  _meson_fixenv
  meson install -C "${MESON_BUILDDIR}"
}

function PostInstall() {
  true
}

function Clean() {
  find "$INSTALLROOT/lib" -name '*.la' -delete 2>/dev/null || true
}

. ${BITS_RECIPE_TOOLS_ROOT}/ModuleRecipe
. ${BITS_RECIPE_TOOLS_ROOT}/PreloadRecipe

function Run() {
  local rc=0
  case $1 in
    Prepare) Prepare ;;
    Build)   Configure && Make && UnitTest && MakeInstall && MakeModule && PostInstall && Preload && Clean ;;
    *)       Prepare && Configure && Make && UnitTest && MakeInstall && MakeModule && PostInstall && Preload && Clean ;;
  esac || rc=$?
  return $rc
}
