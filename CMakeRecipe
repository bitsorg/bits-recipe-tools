CMAKE_BUILDDIR="${CMAKE_BUILDDIR:-.}"

function Prepare() {
  rsync -av --delete --delete-excluded $SOURCEDIR/ ./
}

function Configure() {
  cmake ${CMAKE_BUILDDIR} -DCMAKE_INSTALL_PREFIX="$INSTALLROOT" --log-level DEBUG 
}

function Make() {
  cmake --build ${CMAKE_BUILDDIR} -- ${CMAKE_OPTIONS} ${JOBS:+-j$JOBS}
}

function MakeInstall() {
  cmake --install ${CMAKE_BUILDDIR} 
}

function PostInstall() {
  true
}

function Clean() {
  rm -f $INSTALLROOT/lib/*.la
  rm -rf $INSTALLROOT/share
}

. ${BITS_RECIPE_TOOLS_ROOT}/ModuleRecipe

function Run() {
    mkdir -p build
    pushd build
    case $1 in
	Prepare)
  	  Prepare && popd && return
	  exit 1
	  ;;
	Build)
          Configure && Make && MakeInstall && MakeModule && PostInstall && Clean && popd && return
	  exit 1
          ;;
	*)
          Prepare && Configure && Make && MakeInstall && MakeModule && PostInstall && Clean && popd && return
          ;;
    esac
    exit 1
}


