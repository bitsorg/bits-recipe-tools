function Prepare() {
  rsync -av --delete --exclude '**/.git' --delete-excluded $SOURCEDIR/ ./
}

function Configure() {
  [ -f autogen.sh ] && ./autogen.sh
  ./configure --prefix=$INSTALLROOT
}

function Make() {
  make ${JOBS:+-j $JOBS} 
}

function MakeInstall() {
  make install
}

function PostInstall() {
  true
}

function Clean() {
  rm -f $INSTALLROOT/lib/*.la
}

. ${BITS_RECIPE_TOOLS_ROOT}/ModuleRecipe

function Run() {
    case $1 in
	Prepare)
  	  Prepare && return
	  exit 1
	  ;;
	Build)
	  Configure && Make && MakeInstall && MakeModule && PostInstall && Clean && return
	  exit 1
          ;;
	*)
          Prepare && Configure && Make && MakeInstall && MakeModule && PostInstall && Clean && return
	  exit 1
          ;;
    esac
}


